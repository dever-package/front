{
  "page": {
    "name": "角色管理",
    "icon": "shield",
    "parent": "system-settings",
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增角色",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "权限概览",
              "value": "auths",
              "type": "show-base",
              "meta": {
                "format": "count",
                "countUnit": " 个权限",
                "cases": [
                  {
                    "field": "id",
                    "value": 1,
                    "text": "全部权限"
                  }
                ]
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前角色",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editRoleId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.open",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "xs",
                    "description": "删除当前角色",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteRole",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.open",
          "pageRoute": "/front/role/update",
          "title": "编辑角色",
          "description": "在这里维护角色名称和可访问权限。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editRoleId"
          },
          "size": "2xl",
          "bodyClassName": "px-6 py-2 md:px-8"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/front/role/update",
          "title": "新增角色",
          "description": "创建角色后，可在这里勾选该角色拥有的页面和权限。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "2xl",
          "bodyClassName": "px-6 py-2 md:px-8"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除角色",
        "info": "确认删除当前角色吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteRole"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "角色管理",
      "description": "角色负责聚合菜单和普通权限，账户绑定角色后即可继承授权结果。"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0
    },
    "actionTarget": {
      "editRoleId": "",
      "deleteRole": {}
    }
  },
  "state": {
    "dialog": {
      "open": false,
      "create": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
