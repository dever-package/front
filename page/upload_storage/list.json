{
  "page": {
    "name": "存储方式",
    "icon": "database",
    "parent": "front/upload_rule/list",
    "type": 2,
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回上一页",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "back": true
        }
      },
      {
        "type": "show-button",
        "name": "新增存储方式",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "type",
              "type": "show-tag",
              "meta": {
                "cases": [
                  {
                    "field": "type",
                    "value": "local",
                    "text": "本地"
                  },
                  {
                    "field": "type",
                    "value": "qiniu",
                    "text": "七牛云"
                  }
                ]
              }
            },
            {
              "value": "bucket",
              "type": "show-base"
            },
            {
              "value": "domain",
              "type": "show-base"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前存储方式",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editStorageId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.open",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "xs",
                    "description": "删除当前存储方式",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteStorage",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.open",
          "pageRoute": "/front/upload_storage/update",
          "title": "编辑存储方式",
          "description": "统一维护本地、七牛云等存储配置，上传规则只引用这里的记录。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editStorageId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/front/upload_storage/update",
          "title": "新增存储方式",
          "description": "新存储方式保存后，可在上传规则里直接选择。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除存储方式",
        "info": "确认删除当前存储方式吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteStorage"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "存储方式",
      "description": "把本地、七牛云等存储配置单独维护起来，上传规则只关心引用哪一种存储方式。"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0
    },
    "actionTarget": {
      "editStorageId": "",
      "deleteStorage": {}
    }
  },
  "state": {
    "dialog": {
      "open": false,
      "create": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
