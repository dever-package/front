{
  "page": {
    "name": "账户编辑",
    "parent": "front/account/list",
    "sort": 10,
    "auth": [
      {
        "key": "front/account/create",
        "name": "账户新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "front/account/update",
        "name": "账户编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "请输入真实姓名",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "姓名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "placeholder": "请输入手机号",
        "value": "form.account",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "账户不能为空。"
          },
          {
            "type": "pattern",
            "pattern": "^1\\d{10}$",
            "message": "账户必须是手机号格式。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该账户已存在，请更换。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-password",
        "placeholder": "请输入登录密码",
        "value": "form.password",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "密码不能为空。",
            "when": [
              {
                "path": "form.id",
                "operator": "empty"
              }
            ]
          },
          {
            "type": "min",
            "min": 6,
            "message": "密码至少 6 位。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "placeholder": "请选择角色，可多选",
        "value": "form.role_ids",
        "mode": "form",
        "option": "option.role",
        "validate": [
          {
            "type": "required",
            "message": "角色不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "multiple": true,
          "controlClassName": "max-w-[320px]"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "account": "",
      "password": "",
      "role_ids": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "data": {
        "id": "$form.id",
        "name": "$form.name",
        "account": "$form.account",
        "password": "$form.password",
        "role_id": "$form.role_ids.0",
        "role_ids": "$form.role_ids"
      }
    }
  }
}
