{
  "page": {
    "name": "账户管理",
    "icon": "users-round",
    "parent": "system-settings",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增账户",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      },
      {
        "type": "show-button",
        "name": "操作日志",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "history",
          "to": "/front/account/log/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "account",
              "type": "show-base"
            },
            {
              "value": "roles",
              "type": "show-tag",
              "meta": {
                "field": "name"
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前账户",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editAccountId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.open",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "xs",
                    "description": "删除当前账户",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteAccount",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.open",
          "pageRoute": "/front/account/update",
          "title": "编辑账户",
          "description": "在这里更新登录账户信息，并为账户分配一个或多个角色。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editAccountId"
          },
          "size": "md",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/front/account/update",
          "title": "新增账户",
          "description": "在这里创建登录账户，并为其选择一个或多个角色。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "md",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除账户",
        "info": "确认删除当前账户吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteAccount"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "账户管理",
      "description": "维护后台登录账户，账户可同时绑定多个角色，并继承这些角色的菜单与权限。"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0
    },
    "actionTarget": {
      "editAccountId": "",
      "deleteAccount": {}
    }
  },
  "state": {
    "dialog": {
      "open": false,
      "create": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
