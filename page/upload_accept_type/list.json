{
  "page": {
    "name": "允许类型",
    "icon": "files",
    "parent": "front/upload_rule/list",
    "type": 2,
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-rich",
        "value": "page.titleHtml",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回上一页",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "back": true
        }
      },
      {
        "type": "show-button",
        "name": "新增允许类型",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "accept",
              "type": "show-base",
              "meta": {
                "cases": [
                  {
                    "field": "accept",
                    "value": "",
                    "text": "不限"
                  }
                ]
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前允许类型",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editAcceptTypeId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.open",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "xs",
                    "description": "删除当前允许类型",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteAcceptType",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.open",
          "pageRoute": "/front/upload_accept_type/update",
          "title": "编辑允许类型",
          "description": "把常用的 Accept 规则预先维护起来，上传规则只选择引用哪一种。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editAcceptTypeId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/front/upload_accept_type/update",
          "title": "新增允许类型",
          "description": "新允许类型保存后，可在上传规则里直接选择。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除允许类型",
        "info": "确认删除当前允许类型吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteAcceptType"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "titleHtml": "<div class='flex min-w-0 flex-col gap-0.5'><h1 class='text-xl font-semibold tracking-tight text-foreground'>允许类型</h1><p class='text-sm leading-6 text-muted-foreground'>把常用文件类型预先配置成标准 Accept 规则，上传规则只需要选中对应类型即可。</p></div>"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0
    },
    "actionTarget": {
      "editAcceptTypeId": "",
      "deleteAcceptType": {}
    }
  },
  "state": {
    "dialog": {
      "open": false,
      "create": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
