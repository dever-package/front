{
  "name": "front",
  "version": "0.1.0",
  "description": "Dever front runtime, admin shell, RBAC, upload and system pages",
  "skills": [
    "skills/SKILL.md"
  ],
  "front": {
    "public": [
      "/site/info",
      "/qiniu/callback",
      "/upload/*"
    ],
    "sites": {
      "admin": {
        "api": "front",
        "page": "admin",
        "config": {
          "name": "管理后台",
          "subtitle": "平台配置",
          "description": "Dever 管理后台",
          "logo": "front/assets/admin/images/logo.svg",
          "favicon": "front/assets/admin/images/favicon.svg"
        },
        "setting": {
          "appearance": {
            "theme": "light",
            "sidebar": "floating",
            "layout": "compact",
            "direction": "ltr"
          },
          "runtime": {
            "skin": "default",
            "routerMode": "history"
          }
        },
        "access": {
          "mode": "rbac",
          "authProvider": "front"
        },
        "public": [
          "auth/login"
        ],
        "auth": [
          {
            "key": "config",
            "name": "平台配置",
            "icon": "settings",
            "type": 1,
            "sort": 100
          },
          {
            "key": "system-settings",
            "name": "系统设置",
            "icon": "settings",
            "parent": "config",
            "type": 1,
            "sort": 2
          }
        ]
      },
      "hello": {
        "api": "front",
        "page": "hello",
        "config": {
          "name": "Hello World",
          "subtitle": "Public Demo",
          "description": "Dever public site example",
          "logo": "front/assets/hello/images/logo.svg",
          "favicon": "front/assets/hello/images/favicon.svg"
        },
        "access": {
          "mode": "public",
          "authProvider": "front"
        },
        "entry": "front/hello"
      },
      "home": {
        "api": "home",
        "page": "home",
        "config": {
          "name": "Template Home",
          "subtitle": "Static Render Demo",
          "description": "Dever template render demo site",
          "logo": "front/assets/home/images/logo.svg",
          "favicon": "front/assets/home/images/favicon.svg"
        },
        "access": {
          "mode": "public",
          "authProvider": "front"
        }
      }
    }
  }
}
