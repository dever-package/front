{
  "page": {
    "name": "资源分类编辑",
    "parent": "front/resource/list",
    "sort": 8,
    "auth": [
      {
        "key": "front/upload_file_cate/create",
        "name": "资源分类新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "front/upload_file_cate/update",
        "name": "资源分类编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：头像素材",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "分类名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "placeholder": "例如：100",
        "value": "form.sort",
        "mode": "form",
        "info": "数值越小越靠前，默认 100。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[220px]"
        }
      },
      {
        "type": "form-switch",
        "value": "form.status",
        "mode": "form",
        "info": "停用后不会删除分类，只是不建议继续用于新资源归类。",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": 1,
          "falseValue": 0
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "front.upload.UploadFileCateHook.BeforeSaveUploadFileCate"
      }
    }
  }
}
