{
  "page": {
    "name": "计划任务编辑",
    "parent": "front/cron/list",
    "sort": 10,
    "auth": [
      {
        "key": "front/cron/create",
        "name": "计划任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "front/cron/update",
        "name": "计划任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full",
            "children": {
              "cron-param-page": {
                "type": "container",
                "path": "/front/cron/param/list",
                "className": "mt-5"
              }
            }
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：每天同步团队流程",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.schedule_mode",
        "mode": "form",
        "option": "option.schedule_mode",
        "info": "常用规则会自动生成底层 Cron 表达式；只有复杂场景才使用高级 Cron。",
        "meta": {
          "formLayout": "horizontal",
          "orientation": "horizontal",
          "clearOnChange": [
            "form.interval_seconds",
            "form.interval_minutes",
            "form.hourly_minute",
            "form.daily_time",
            "form.weekly_weekday",
            "form.weekly_time",
            "form.monthly_day",
            "form.monthly_time"
          ]
        }
      },
      {
        "type": "form-number",
        "value": "form.interval_seconds",
        "mode": "form",
        "info": "例如填写 5 表示每 5 秒运行一次，范围 1-59。",
        "validate": [
          {
            "type": "required",
            "message": "间隔秒数不能为空。",
            "when": [
              {
                "path": "form.schedule_mode",
                "operator": "equals",
                "value": "every_seconds"
              }
            ]
          },
          {
            "type": "min",
            "min": 1,
            "message": "间隔秒数不能小于 1。"
          },
          {
            "type": "max",
            "max": 59,
            "message": "间隔秒数不能大于 59。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "every_seconds"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "value": "form.interval_minutes",
        "mode": "form",
        "info": "例如填写 5 表示每 5 分钟运行一次，范围 1-59。",
        "validate": [
          {
            "type": "required",
            "message": "间隔分钟不能为空。",
            "when": [
              {
                "path": "form.schedule_mode",
                "operator": "equals",
                "value": "every_minutes"
              }
            ]
          },
          {
            "type": "min",
            "min": 1,
            "message": "间隔分钟不能小于 1。"
          },
          {
            "type": "max",
            "max": 59,
            "message": "间隔分钟不能大于 59。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "every_minutes"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "value": "form.hourly_minute",
        "mode": "form",
        "info": "每小时的第几分钟运行，范围 0-59。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "hourly"
            }
          ]
        }
      },
      {
        "type": "form-input",
        "placeholder": "02:00",
        "value": "form.daily_time",
        "mode": "form",
        "info": "每天运行时间，格式 HH:mm。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "daily"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "value": "form.weekly_weekday",
        "mode": "form",
        "option": "option.weekday",
        "meta": {
          "formLayout": "horizontal",
          "orientation": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "weekly"
            }
          ]
        }
      },
      {
        "type": "form-input",
        "placeholder": "02:00",
        "value": "form.weekly_time",
        "mode": "form",
        "info": "每周运行时间，格式 HH:mm。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "weekly"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "value": "form.monthly_day",
        "mode": "form",
        "info": "每月第几天运行。为避免大小月问题，第一版限制 1-28。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "monthly"
            }
          ]
        }
      },
      {
        "type": "form-input",
        "placeholder": "02:00",
        "value": "form.monthly_time",
        "mode": "form",
        "info": "每月运行时间，格式 HH:mm。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "monthly"
            }
          ]
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：*/5 * * * *",
        "value": "form.spec",
        "mode": "form",
        "info": "支持 5 段标准 cron 或 6 段秒级 cron。",
        "validate": [
          {
            "type": "required",
            "message": "Cron 表达式不能为空。",
            "when": [
              {
                "path": "form.schedule_mode",
                "operator": "equals",
                "value": "cron"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[320px]",
          "hiddenWhen": [
            {
              "path": "form.schedule_mode",
              "operator": "notEquals",
              "value": "cron"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "value": "form.timezone",
        "mode": "form",
        "option": "option.timezone",
        "meta": {
          "formLayout": "horizontal",
          "orientation": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.kind",
        "mode": "form",
        "option": "option.kind",
        "meta": {
          "formLayout": "horizontal",
          "orientation": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "内部业务",
        "placeholder": "请选择内部业务",
        "value": "form.use",
        "mode": "form",
        "option": {
          "type": "service",
          "service": "front.cron.CronOptionService.LoadCronProviders",
          "valueField": "id",
          "labelField": "value"
        },
        "validate": [
          {
            "type": "required",
            "message": "内部业务不能为空。"
          }
        ],
        "info": "只允许调用已注册的内部业务执行器，不支持任意 shell 或外部 URL。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[320px]"
        }
      },
      {
        "type": "form-number",
        "value": "form.timeout_seconds",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "超时时间不能为空。"
          }
        ],
        "info": "单位秒。超时后运行记录会标记为失败，最大 86400 秒。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "name",
        "status",
        "schedule_mode",
        "schedule_config",
        "interval_seconds",
        "interval_minutes",
        "hourly_minute",
        "daily_time",
        "weekly_weekday",
        "weekly_time",
        "monthly_day",
        "monthly_time",
        "spec",
        "timezone",
        "kind",
        "use",
        "payload_json",
        "params",
        "timeout_seconds"
      ],
      "id": "",
      "name": "",
      "status": 1,
      "schedule_mode": "every_minutes",
      "schedule_config": "{}",
      "interval_seconds": 5,
      "interval_minutes": 5,
      "hourly_minute": 0,
      "daily_time": "02:00",
      "weekly_weekday": 1,
      "weekly_time": "02:00",
      "monthly_day": 1,
      "monthly_time": "02:00",
      "spec": "*/5 * * * *",
      "timezone": "Asia/Shanghai",
      "kind": "provider",
      "use": "",
      "payload_json": "{}",
      "params": [],
      "timeout_seconds": 300
    },
    "option": {
      "schedule_mode": [
        {
          "id": "every_seconds",
          "value": "每隔N秒"
        },
        {
          "id": "every_minutes",
          "value": "每隔N分钟"
        },
        {
          "id": "hourly",
          "value": "每小时"
        },
        {
          "id": "daily",
          "value": "每天"
        },
        {
          "id": "weekly",
          "value": "每周"
        },
        {
          "id": "monthly",
          "value": "每月"
        },
        {
          "id": "cron",
          "value": "高级Cron"
        }
      ],
      "weekday": [
        {
          "id": 1,
          "value": "周一"
        },
        {
          "id": 2,
          "value": "周二"
        },
        {
          "id": 3,
          "value": "周三"
        },
        {
          "id": 4,
          "value": "周四"
        },
        {
          "id": 5,
          "value": "周五"
        },
        {
          "id": 6,
          "value": "周六"
        },
        {
          "id": 0,
          "value": "周日"
        }
      ],
      "timezone": [
        {
          "id": "Asia/Shanghai",
          "value": "Asia/Shanghai"
        },
        {
          "id": "UTC",
          "value": "UTC"
        }
      ],
      "kind": [
        {
          "id": "provider",
          "value": "内部业务"
        }
      ]
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "front.cron.CronHook.BeforeSaveCron"
      },
      "data": {
        "id": "$form.id",
        "name": "$form.name",
        "status": "$form.status",
        "schedule_mode": "$form.schedule_mode",
        "schedule_config": "$form.schedule_config",
        "spec": "$form.spec",
        "timezone": "$form.timezone",
        "kind": "$form.kind",
        "use": "$form.use",
        "payload_json": "$form.payload_json",
        "params": "$form.params",
        "timeout_seconds": "$form.timeout_seconds",
        "updated_at": "$form.updated_at"
      }
    }
  }
}
